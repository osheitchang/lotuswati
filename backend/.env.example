NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql://lotuswati:lotuswati_password@localhost:5432/lotuswati

# Required in all environments.
JWT_SECRET=replace-with-a-long-random-secret
WA_VERIFY_TOKEN=replace-with-a-long-random-token

# Optional request-throttling controls
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300
AUTH_RATE_LIMIT_MAX_REQUESTS=20

# Optional for WhatsApp Cloud API (app runs in mock mode if not set)
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
